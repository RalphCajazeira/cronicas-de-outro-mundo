generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ActorType {
  CHARACTER
  NPC
  CREATURE
  COMPANION
  SPIRIT
}

enum ActorStatus {
  ACTIVE
  INACTIVE
  DEFEATED
  DEAD
  ARCHIVED
}

enum ActorAttributeCode {
  STRENGTH     @map("strength")
  VITALITY     @map("vitality")
  AGILITY      @map("agility")
  DEXTERITY    @map("dexterity")
  INTELLIGENCE @map("intelligence")
  WISDOM       @map("wisdom")
  PERCEPTION   @map("perception")
  WILLPOWER    @map("willpower")
  LUCK         @map("luck")
}

enum ActorResourceType {
  HP   @map("hp")
  MANA @map("mana")
  SP   @map("sp")
}

enum ContentType {
  SKILL
  SPELL
  WEAPON
  ARMOR
  SHIELD
  CLOTHING
  ITEM
  CONSUMABLE
  TALENT
  MATERIAL
  CLASS
  RACE
  LOCATION
  FACTION
  QUEST_TEMPLATE
  STATUS_EFFECT
  RECIPE
  CREATURE_TEMPLATE
  OTHER
}

enum ContentProfileMode {
  MECHANICAL
  NARRATIVE
  GENERIC
}

enum ContentStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ActorContentState {
  LOCKED
  LEARNING
  KNOWN
  MASTERED
}

enum InventoryEntryKind {
  INSTANCE
  STACK
}

enum InventoryInstanceLifecycle {
  AVAILABLE
  RESERVED
  CONSUMED
  DESTROYED
}

enum ActorEquipmentSlotRef {
  MAIN_HAND
  OFF_HAND
  HEAD
  CHEST
  HANDS
  LEGS
  FEET
  BODY
  ACCESSORY_1
  ACCESSORY_2
}

enum ContentEffectBindingKind {
  APPLY_STATUS
  REMOVE_STATUS
}

enum ActiveEffectKind {
  STATUS
  PRIMARY_MODIFIER
  SECONDARY_MODIFIER
  REACTION_GRANT
}

enum ActiveEffectDurationType {
  TICKS
  ACTIONS
  SCENE
  ENCOUNTER
  PERMANENT
}

enum EffectResolutionOperation {
  EXECUTE_CONTENT
  USE_CONSUMABLE
}

enum EffectRollKind {
  HIT
  CRITICAL
  CONCENTRATION
}

enum EncounterLifecycleStatus {
  AWAITING_INTENT
  AWAITING_REACTION
  PROCESSING_PAUSED
  COMPLETION_PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum EncounterStopReason {
  PLAN_COMPLETED
  ACTOR_INCAPACITATED
  HOSTILE_BECAME_READY
  TARGET_SET_CHANGED
  RESOURCE_BELOW_REQUIRED
  ZONE_CHANGED
  NEW_THREAT_DETECTED
  STATE_VERSION_CHANGED
  PROCESSING_LIMIT
  NO_VALID_TARGET
  REACTION_REQUIRED
  NEW_INTENT_REQUIRED
  ENCOUNTER_COMPLETED
  ENCOUNTER_FAILED
}

enum EncounterCompletionCandidate {
  PARTY_VICTORY_CANDIDATE
  HOSTILE_VICTORY_CANDIDATE
  STALEMATE_CANDIDATE
  CANCELLED
}

enum EncounterOutcome {
  PARTY_VICTORY
  PARTY_DEFEAT
  STALEMATE
  CANCELLED
}

enum EncounterParticipantBindingKind {
  PERSISTED_ACTOR
  EPHEMERAL
}

enum EncounterEphemeralKind {
  SUMMON
  PROJECTION
  EPHEMERAL_CREATURE
}

enum EncounterOperationKind {
  CREATE
  SUBMIT_INTENT
  RESOLVE_REACTION
  CONTINUE
  CONFIRM_COMPLETION
  CANCEL
}

enum EncounterRollKind {
  TIE_BREAK
  HIT
  CRITICAL
  CONCENTRATION
  BLOCK
  ACTIVE_DODGE
  INTERRUPT
  COUNTER_ATTACK
}

model Player {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  worlds      World[]
}

model Ruleset {
  id        String           @id @default(uuid()) @db.Uuid
  code      String           @unique
  name      String
  createdAt DateTime         @default(now())
  versions  RulesetVersion[]
}

model RulesetVersion {
  id                     String                  @id @default(uuid()) @db.Uuid
  rulesetId              String                  @db.Uuid
  code                   String                  @unique
  revision               String
  schemaVersion          Int
  configHash             String                  @db.Char(64)
  configSnapshot         Json
  createdAt              DateTime                @default(now())
  ruleset                Ruleset                 @relation(fields: [rulesetId], references: [id], onDelete: Restrict)
  defaultWorlds          World[]                 @relation("WorldDefaultRulesetVersion")
  campaigns              Campaign[]              @relation("CampaignRulesetVersion")
  actorSnapshots         ActorDerivedSnapshot[]
  contentProfiles        ContentProfileVersion[]
  contentVersions        ContentVersion[]
  inventoryRulesVersions InventoryRulesVersion[]
  effectRulesVersions    EffectRulesVersion[]
  encounters             Encounter[]

  @@index([rulesetId])
}

model World {
  id                      String              @id @default(uuid()) @db.Uuid
  playerId                String              @db.Uuid
  defaultRulesetVersionId String              @db.Uuid
  code                    String
  name                    String
  description             String?
  metadata                Json                @default("{}")
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  player                  Player              @relation(fields: [playerId], references: [id], onDelete: Cascade)
  defaultRulesetVersion   RulesetVersion      @relation("WorldDefaultRulesetVersion", fields: [defaultRulesetVersionId], references: [id], onDelete: Restrict)
  campaigns               Campaign[]
  content                 ContentDefinition[]

  @@unique([playerId, code])
  @@index([defaultRulesetVersionId])
}

model Campaign {
  id                 String              @id @default(uuid()) @db.Uuid
  worldId            String              @db.Uuid
  rulesetVersionId   String              @db.Uuid
  code               String
  name               String
  status             CampaignStatus      @default(DRAFT)
  currentTime        Json?
  engineTick         BigInt              @default(0)
  engineStateVersion Int                 @default(1)
  metadata           Json                @default("{}")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  world              World               @relation(fields: [worldId], references: [id], onDelete: Cascade)
  rulesetVersion     RulesetVersion      @relation("CampaignRulesetVersion", fields: [rulesetVersionId], references: [id], onDelete: Restrict)
  actors             Actor[]
  content            ContentDefinition[]
  events             GameEvent[]
  effectResolutions  EffectResolution[]
  encounters         Encounter[]

  @@unique([worldId, code])
  @@index([rulesetVersionId])
}

model Actor {
  id                        String                @id @default(uuid()) @db.Uuid
  campaignId                String                @db.Uuid
  code                      String
  name                      String
  actorType                 ActorType
  species                   String?
  className                 String?
  role                      String?
  description               String?
  level                     Int                   @default(1)
  xp                        Int                   @default(0)
  gold                      Int                   @default(0)
  mechanicsStateVersion     Int                   @default(1)
  inventoryStateVersion     Int                   @default(1)
  effectsStateVersion       Int                   @default(1)
  appearance                Json                  @default("{}")
  personality               Json                  @default("{}")
  metadata                  Json                  @default("{}")
  status                    ActorStatus           @default(ACTIVE)
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  campaign                  Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  attributes                ActorAttribute[]
  resources                 ActorResource[]
  derivedSnapshot           ActorDerivedSnapshot?
  content                   ActorContent[]
  inventoryEntries          InventoryEntry[]
  equipmentSlots            ActorEquipmentSlot[]
  events                    GameEvent[]
  sourcedActiveEffects      ActiveEffect[]        @relation("ActiveEffectSourceActor")
  targetedActiveEffects     ActiveEffect[]        @relation("ActiveEffectTargetActor")
  sourcedEffectResolutions  EffectResolution[]    @relation("EffectResolutionSourceActor")
  targetedEffectResolutions EffectResolution[]    @relation("EffectResolutionTargetActor")
  encounterParticipants    EncounterParticipant[]

  @@unique([campaignId, code])
  @@index([campaignId, actorType, status])
}

model ActorAttribute {
  id          String             @id @default(uuid()) @db.Uuid
  actorId     String             @db.Uuid
  code        ActorAttributeCode
  baseValue   Int
  earnedValue Int                @default(0)
  xp          Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  actor       Actor              @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@unique([actorId, code])
}

model ActorResource {
  id           String            @id @default(uuid()) @db.Uuid
  actorId      String            @db.Uuid
  type         ActorResourceType
  current      Int
  stateVersion Int               @default(1)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  actor        Actor             @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@unique([actorId, type])
}

model ActorDerivedSnapshot {
  id                          String         @id @default(uuid()) @db.Uuid
  actorId                     String         @unique @db.Uuid
  rulesetVersionId            String         @db.Uuid
  mechanicsStateVersion       Int
  inventoryStateVersion       Int
  effectsStateVersion         Int
  maxHp                       Int
  maxMana                     Int
  maxSp                       Int
  actorPhysicalPower          Int
  actorMagicalPower           Int
  physicalDefense             Int
  magicalDefense              Int
  accuracy                    Int
  evasion                     Int
  baseAttackSpeedBps          Int
  baseCastingSpeedBps         Int
  criticalChanceBps           Int
  criticalDamageBps           Int
  movementSpeed               Int
  carryingCapacity            Int
  physicalResistanceBps       Int
  magicalResistanceBps        Int
  elementalResistanceSnapshot Json           @default("{}")
  hpRegen                     Int
  manaRegen                   Int
  spRegen                     Int
  inputHash                   String         @db.Char(64)
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt
  actor                       Actor          @relation(fields: [actorId], references: [id], onDelete: Cascade)
  rulesetVersion              RulesetVersion @relation(fields: [rulesetVersionId], references: [id], onDelete: Restrict)

  @@index([rulesetVersionId])
}

model ContentDefinition {
  id                     String                 @id @default(uuid()) @db.Uuid
  worldId                String                 @db.Uuid
  campaignId             String?                @db.Uuid
  code                   String
  contentType            ContentType
  status                 ContentStatus          @default(DRAFT)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  world                  World                  @relation(fields: [worldId], references: [id], onDelete: Cascade)
  campaign               Campaign?              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  versions               ContentVersion[]
  actors                 ActorContent[]
  targetedEffectBindings ContentEffectBinding[] @relation("ContentEffectBindingTargetDefinition")

  @@unique([worldId, campaignId, contentType, code])
  @@unique([worldId, contentType, code], map: "ContentDefinition_global_scope_key", where: { campaignId: null })
  @@index([worldId, contentType, code])
}

model ContentProfileVersion {
  id               String           @id @default(uuid()) @db.Uuid
  rulesetVersionId String           @db.Uuid
  code             String           @unique
  schemaVersion    Int
  configHash       String           @db.Char(64)
  configSnapshot   Json
  createdAt        DateTime         @default(now())
  rulesetVersion   RulesetVersion   @relation(fields: [rulesetVersionId], references: [id], onDelete: Restrict)
  contentVersions  ContentVersion[]

  @@index([rulesetVersionId])
}

model InventoryRulesVersion {
  id               String           @id @default(uuid()) @db.Uuid
  rulesetVersionId String           @db.Uuid
  code             String           @unique
  schemaVersion    Int
  configHash       String           @db.Char(64)
  configSnapshot   Json
  createdAt        DateTime         @default(now())
  rulesetVersion   RulesetVersion   @relation(fields: [rulesetVersionId], references: [id], onDelete: Restrict)
  contentVersions  ContentVersion[]
  inventoryEntries InventoryEntry[]

  @@index([rulesetVersionId])
}

model EffectRulesVersion {
  id                String             @id @default(uuid()) @db.Uuid
  rulesetVersionId  String             @db.Uuid
  code              String             @unique
  schemaVersion     Int
  configHash        String             @db.Char(64)
  configSnapshot    Json
  createdAt         DateTime           @default(now())
  rulesetVersion    RulesetVersion     @relation(fields: [rulesetVersionId], references: [id], onDelete: Restrict)
  activeEffects     ActiveEffect[]
  effectResolutions EffectResolution[]

  @@index([rulesetVersionId])
}

model ContentVersion {
  id                      String                 @id @default(uuid()) @db.Uuid
  contentDefinitionId     String                 @db.Uuid
  rulesetVersionId        String                 @db.Uuid
  contentProfileVersionId String                 @db.Uuid
  inventoryRulesVersionId String?                @db.Uuid
  versionNumber           Int
  schemaVersion           Int
  profileMode             ContentProfileMode
  name                    String
  description             String?
  profile                 Json?
  presentation            Json                   @default("{}")
  tags                    Json                   @default("[]")
  metadata                Json                   @default("{}")
  contentHash             String                 @db.Char(64)
  inventorySpec           Json?
  inventorySpecHash       String?                @db.Char(64)
  effectBindingHash       String                 @default("4f53cda18c2baa0c0354bb5f9a3ecbe5ed12ab4d8e11ba873c2f11161202b945") @db.Char(64)
  createdAt               DateTime               @default(now())
  contentDefinition       ContentDefinition      @relation(fields: [contentDefinitionId], references: [id], onDelete: Restrict)
  rulesetVersion          RulesetVersion         @relation(fields: [rulesetVersionId], references: [id], onDelete: Restrict)
  contentProfileVersion   ContentProfileVersion  @relation(fields: [contentProfileVersionId], references: [id], onDelete: Restrict)
  inventoryRulesVersion   InventoryRulesVersion? @relation(fields: [inventoryRulesVersionId], references: [id], onDelete: Restrict)
  actors                  ActorContent[]
  inventoryEntries        InventoryEntry[]
  sourceEffectBindings    ContentEffectBinding[] @relation("ContentEffectBindingSourceVersion")
  targetEffectBindings    ContentEffectBinding[] @relation("ContentEffectBindingTargetVersion")
  sourcedActiveEffects    ActiveEffect[]         @relation("ActiveEffectSourceContentVersion")
  effectActiveEffects     ActiveEffect[]         @relation("ActiveEffectContentVersion")
  effectResolutions       EffectResolution[]

  @@unique([contentDefinitionId, versionNumber])
  @@unique([contentDefinitionId, contentHash, effectBindingHash], map: "ContentVersion_without_inventory_spec_key", where: { inventorySpecHash: null })
  @@unique([contentDefinitionId, contentHash, inventorySpecHash, effectBindingHash], map: "ContentVersion_with_inventory_spec_key", where: { inventorySpecHash: { not: null } })
  @@unique([id, contentDefinitionId])
  @@index([contentDefinitionId, versionNumber(sort: Desc)])
  @@index([rulesetVersionId])
  @@index([contentProfileVersionId])
  @@index([inventoryRulesVersionId])
}

model ContentEffectBinding {
  id                        String                   @id @default(uuid()) @db.Uuid
  sourceContentVersionId    String                   @db.Uuid
  effectIndex               Int
  bindingKind               ContentEffectBindingKind
  targetContentDefinitionId String                   @db.Uuid
  targetContentVersionId    String                   @db.Uuid
  createdAt                 DateTime                 @default(now())
  sourceContentVersion      ContentVersion           @relation("ContentEffectBindingSourceVersion", fields: [sourceContentVersionId], references: [id], onDelete: Restrict)
  targetContentDefinition   ContentDefinition        @relation("ContentEffectBindingTargetDefinition", fields: [targetContentDefinitionId], references: [id], onDelete: Restrict)
  targetContentVersion      ContentVersion           @relation("ContentEffectBindingTargetVersion", fields: [targetContentVersionId, targetContentDefinitionId], references: [id, contentDefinitionId], onDelete: Restrict)

  @@unique([sourceContentVersionId, effectIndex, bindingKind])
  @@index([targetContentVersionId, targetContentDefinitionId])
}

model ActorContent {
  id                  String            @id @default(uuid()) @db.Uuid
  actorId             String            @db.Uuid
  contentDefinitionId String            @db.Uuid
  contentVersionId    String            @db.Uuid
  state               ActorContentState @default(LOCKED)
  rank                Int               @default(0)
  progress            Int               @default(0)
  mastery             Int               @default(0)
  notes               String?
  metadata            Json              @default("{}")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  actor               Actor             @relation(fields: [actorId], references: [id], onDelete: Cascade)
  contentDefinition   ContentDefinition @relation(fields: [contentDefinitionId], references: [id], onDelete: Cascade)
  contentVersion      ContentVersion    @relation(fields: [contentVersionId, contentDefinitionId], references: [id, contentDefinitionId], onDelete: Restrict)

  @@unique([actorId, contentDefinitionId])
  @@index([contentVersionId, contentDefinitionId])
}

model InventoryEntry {
  id                      String                      @id @default(uuid()) @db.Uuid
  actorId                 String                      @db.Uuid
  entryRef                String
  contentVersionId        String                      @db.Uuid
  inventoryRulesVersionId String                      @db.Uuid
  entryKind               InventoryEntryKind
  quantity                Int
  instanceLifecycle       InventoryInstanceLifecycle?
  customName              String?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  actor                   Actor                       @relation(fields: [actorId], references: [id], onDelete: Cascade)
  contentVersion          ContentVersion              @relation(fields: [contentVersionId], references: [id], onDelete: Restrict)
  inventoryRulesVersion   InventoryRulesVersion       @relation(fields: [inventoryRulesVersionId], references: [id], onDelete: Restrict)
  equipmentSlots          ActorEquipmentSlot[]

  @@unique([actorId, entryRef])
  @@unique([id, actorId])
  @@index([contentVersionId])
  @@index([inventoryRulesVersionId])
}

model ActorEquipmentSlot {
  id               String                @id @default(uuid()) @db.Uuid
  actorId          String                @db.Uuid
  slotRef          ActorEquipmentSlotRef
  inventoryEntryId String                @db.Uuid
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  actor            Actor                 @relation(fields: [actorId], references: [id], onDelete: Cascade)
  inventoryEntry   InventoryEntry        @relation(fields: [inventoryEntryId, actorId], references: [id, actorId], onDelete: Restrict)

  @@unique([actorId, slotRef])
  @@index([inventoryEntryId, actorId])
}

model ActiveEffect {
  id                     String                   @id @default(uuid()) @db.Uuid
  targetActorId          String                   @db.Uuid
  sourceActorId          String                   @db.Uuid
  sourceContentVersionId String                   @db.Uuid
  effectContentVersionId String?                  @db.Uuid
  effectRulesVersionId   String                   @db.Uuid
  originEncounterId      String?                  @db.Uuid
  effectRef              String
  effectIndex            Int
  kind                   ActiveEffectKind
  stacks                 Int
  appliedAtTick          BigInt
  durationType           ActiveEffectDurationType
  expiresAtTick          BigInt?
  remainingActions       Int?
  payload                Json
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  targetActor            Actor                    @relation("ActiveEffectTargetActor", fields: [targetActorId], references: [id], onDelete: Cascade)
  sourceActor            Actor                    @relation("ActiveEffectSourceActor", fields: [sourceActorId], references: [id], onDelete: Cascade)
  sourceContentVersion   ContentVersion           @relation("ActiveEffectSourceContentVersion", fields: [sourceContentVersionId], references: [id], onDelete: Restrict)
  effectContentVersion   ContentVersion?          @relation("ActiveEffectContentVersion", fields: [effectContentVersionId], references: [id], onDelete: Restrict)
  effectRulesVersion     EffectRulesVersion       @relation(fields: [effectRulesVersionId], references: [id], onDelete: Restrict)
  originEncounter        Encounter?               @relation(fields: [originEncounterId], references: [id], onDelete: Restrict)

  @@unique([targetActorId, effectRef])
  @@unique([targetActorId, effectContentVersionId], map: "ActiveEffect_status_version_key", where: { effectContentVersionId: { not: null } })
  @@unique([targetActorId, sourceContentVersionId, effectIndex, kind], map: "ActiveEffect_direct_origin_key")
  @@index([targetActorId, expiresAtTick])
  @@index([sourceActorId])
  @@index([sourceContentVersionId])
  @@index([effectRulesVersionId])
  @@index([originEncounterId, targetActorId])
}

model EffectResolution {
  id                     String                    @id @default(uuid()) @db.Uuid
  campaignId             String                    @db.Uuid
  sourceActorId          String                    @db.Uuid
  targetActorId          String?                   @db.Uuid
  sourceContentVersionId String                    @db.Uuid
  effectRulesVersionId   String                    @db.Uuid
  operation              EffectResolutionOperation
  idempotencyKey         String                    @unique
  engineTick             BigInt
  requestHash            String                    @db.Char(64)
  resultHash             String                    @db.Char(64)
  resultSnapshot         Json
  createdAt              DateTime                  @default(now())
  campaign               Campaign                  @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  sourceActor            Actor                     @relation("EffectResolutionSourceActor", fields: [sourceActorId], references: [id], onDelete: Restrict)
  targetActor            Actor?                    @relation("EffectResolutionTargetActor", fields: [targetActorId], references: [id], onDelete: Restrict)
  sourceContentVersion   ContentVersion            @relation(fields: [sourceContentVersionId], references: [id], onDelete: Restrict)
  effectRulesVersion     EffectRulesVersion        @relation(fields: [effectRulesVersionId], references: [id], onDelete: Restrict)
  rolls                  EffectRoll[]

  @@index([campaignId, createdAt])
  @@index([sourceActorId, createdAt])
  @@index([targetActorId, createdAt])
  @@index([sourceContentVersionId])
  @@index([effectRulesVersionId])
}

model EffectRoll {
  id                 String           @id @default(uuid()) @db.Uuid
  effectResolutionId String           @db.Uuid
  kind               EffectRollKind
  ordinal            Int
  rollBps            Int
  chanceBps          Int
  success            Boolean
  createdAt          DateTime         @default(now())
  effectResolution   EffectResolution @relation(fields: [effectResolutionId], references: [id], onDelete: Cascade)

  @@unique([effectResolutionId, kind, ordinal])
}

model GameEvent {
  id             String   @id @default(uuid()) @db.Uuid
  campaignId     String   @db.Uuid
  actorId        String?  @db.Uuid
  eventType      String
  title          String
  payload        Json     @default("{}")
  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actor          Actor?   @relation(fields: [actorId], references: [id], onDelete: SetNull)
  encounterConsequence EncounterConsequence?

  @@index([campaignId, createdAt])
  @@index([actorId, createdAt])
}

model IdempotencyRecord {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  operation   String
  requestHash String
  response    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  encounterOperation EncounterOperation?

  @@index([createdAt])
}

model Encounter {
  id                      String                       @id @default(uuid()) @db.Uuid
  campaignId              String                       @db.Uuid
  rulesetVersionId        String                       @db.Uuid
  encounterRef            String
  lifecycleStatus         EncounterLifecycleStatus
  stateVersion            Int
  currentTick             BigInt
  stopReason              EncounterStopReason?
  completionCandidate     EncounterCompletionCandidate?
  snapshotSchemaVersion   Int                          @default(1)
  stateSnapshot           Json
  stateHash               String                       @db.Char(64)
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  closedAt                DateTime?
  campaign                Campaign                     @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  rulesetVersion          RulesetVersion               @relation(fields: [rulesetVersionId], references: [id], onDelete: Restrict)
  participants            EncounterParticipant[]
  operations              EncounterOperation[]
  rolls                   EncounterRoll[]
  originatedActiveEffects ActiveEffect[]
  consequence             EncounterConsequence?

  @@unique([campaignId, encounterRef])
  @@index([campaignId, lifecycleStatus])
  @@index([rulesetVersionId])
}

model EncounterParticipant {
  id                           String                          @id @default(uuid()) @db.Uuid
  encounterId                  String                          @db.Uuid
  actorId                      String?                         @db.Uuid
  actorRef                     String
  bindingKind                  EncounterParticipantBindingKind
  ephemeralKind                EncounterEphemeralKind?
  initialMechanicsStateVersion Int?
  initialInventoryStateVersion Int?
  initialEffectsStateVersion   Int?
  createdAt                    DateTime                        @default(now())
  encounter                    Encounter                       @relation(fields: [encounterId], references: [id], onDelete: Restrict)
  actor                        Actor?                          @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@unique([encounterId, actorRef])
  @@unique([encounterId, actorId], map: "EncounterParticipant_encounterId_actorId_key", where: { actorId: { not: null } })
  @@index([actorId])
}

model EncounterOperation {
  id                  String                 @id @default(uuid()) @db.Uuid
  encounterId         String                 @db.Uuid
  idempotencyRecordId String                 @unique @db.Uuid
  operation           EncounterOperationKind
  previousStateVersion Int
  nextStateVersion    Int
  inputHash           String                 @db.Char(64)
  beforeStateHash     String                 @db.Char(64)
  afterStateHash      String                 @db.Char(64)
  stopReason          EncounterStopReason?
  resultSummary       Json
  createdAt           DateTime               @default(now())
  encounter           Encounter              @relation(fields: [encounterId], references: [id], onDelete: Restrict)
  idempotencyRecord   IdempotencyRecord      @relation(fields: [idempotencyRecordId], references: [id], onDelete: Restrict)
  rolls               EncounterRoll[]
  consequence         EncounterConsequence?

  @@unique([encounterId, nextStateVersion])
  @@unique([id, encounterId])
  @@index([encounterId, createdAt])
}

model EncounterConsequence {
  id                       String             @id @default(uuid()) @db.Uuid
  encounterId              String             @unique @db.Uuid
  encounterOperationId     String             @unique @db.Uuid
  gameEventId              String             @unique @db.Uuid
  consequenceSchemaVersion Int                @default(1)
  rewardPolicyVersion      String?
  outcome                  EncounterOutcome
  resultSummary            Json
  createdAt                DateTime           @default(now())
  encounter                Encounter          @relation(fields: [encounterId], references: [id], onDelete: Restrict)
  encounterOperation       EncounterOperation @relation(fields: [encounterOperationId, encounterId], references: [id, encounterId], onDelete: Restrict)
  gameEvent                GameEvent          @relation(fields: [gameEventId], references: [id], onDelete: Restrict)

  @@unique([encounterOperationId, encounterId])
  @@index([outcome, createdAt])
}

model EncounterRoll {
  id                   String              @id @default(uuid()) @db.Uuid
  encounterId          String              @db.Uuid
  encounterOperationId String              @db.Uuid
  rollRef              String
  kind                 EncounterRollKind
  ordinal              Int
  actionRef            String?
  sourceActorRef        String
  targetActorRef        String?
  targetOrdinal        Int?
  inputHash             String              @db.Char(64)
  resultSnapshot        Json
  resultHash            String              @db.Char(64)
  createdAt             DateTime            @default(now())
  encounter             Encounter           @relation(fields: [encounterId], references: [id], onDelete: Restrict)
  encounterOperation    EncounterOperation  @relation(fields: [encounterOperationId, encounterId], references: [id, encounterId], onDelete: Restrict)

  @@unique([encounterId, rollRef])
  @@index([encounterOperationId, encounterId])
}
